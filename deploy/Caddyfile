{$CADDY_DOMAIN} {
	# API и health-эндпоинты — БЕЗ Basic Auth: к ним ходят и клиент-ноутбук
	# (кросс-домен, без пароля), и сам PWA (same-origin). Пароль здесь сломал
	# бы клиента-ноутбука. Совпадает первым, поэтому оценивается раньше catch-all.
	@backend path /api/* /health*
	handle @backend {
		reverse_proxy api:4000
	}

	# Скачивание готового zip-архива PWA за паролем (логин voxmate).
	# /download/voxmate-pwa.zip → /srv/pwa/voxmate-pwa.zip (префикс срезается).
	handle_path /download/* {
		basic_auth {
			voxmate $2a$14$9Zen4VjrvBxGIgHGOjkOSeJDBIXe5EGiYL/zwpfX4KMmtLXGFE3Na
		}
		root * /srv/pwa
		file_server
	}

	# Сам PWA — БЕЗ Basic Auth: иначе Chrome/Android не может установить
	# приложение (движок установки и service worker подгружают манифест/иконки/
	# ассеты в отдельном контексте, где введённого во вкладке пароля нет → 401 →
	# не устанавливается). Доступ к данным защищён логином приложения
	# (регистрация закрыта, ALLOW_REGISTRATION=false). Статика + SPA-фолбэк.
	handle {
		root * /srv/app
		try_files {path} /index.html
		file_server
	}
}
