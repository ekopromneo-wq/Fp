PORT=4000
WEB_PORT=4173
NODE_ENV=development
# Comma-separated list of origins allowed to make credentialed API requests.
# Defaults to http://localhost:$WEB_PORT if unset - override with the real
# frontend origin(s) in production.
CORS_ALLOWED_ORIGINS=

# --- Split deployment (docker-compose.server.yml / docker-compose.client.yml) ---
# Server host only: public domain Caddy requests a Let's Encrypt cert for and
# reverse-proxies to the api container. Leave unset to serve plain HTTP on :80.
CADDY_DOMAIN=

DATABASE_URL=postgresql://postgres:password@db:5432/voxmate
POSTGRES_DB=voxmate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voxmate-audio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

OPENROUTER_API_KEY=
OPENROUTER_ASR_MODEL=openai/whisper-large-v3
OPENROUTER_ASR_LANGUAGE=ru
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
ASR_COMPRESS_THRESHOLD_BYTES=20971520
ASR_COMPRESSED_BITRATE=32k
ASR_MAX_RETRIES=3
RECORDING_JOB_ATTEMPTS=3
RECORDING_JOB_BACKOFF_MS=15000

SHOPOT_API_KEY=
SPEECH2TEXT_API_KEY=

PIPELINE_CHUNK_SECONDS=480
PIPELINE_WHISPER_MODEL=openai/whisper-large-v3
PIPELINE_VOICE_MODEL=google/gemini-2.5-pro
PIPELINE_IDENTITY_MODEL=anthropic/claude-sonnet-5
PIPELINE_WHISPER_CONCURRENCY=3

RECORDER_BOT_URL=http://recorder-bot:8100
RECORDER_BOT_INTERNAL_SECRET=
API_INTERNAL_URL=http://api:4000

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
BITRIX_WEBHOOK_URL=
BITRIX_DEFAULT_RESPONSIBLE_ID=
BITRIX_DEFAULT_GROUP_ID=

# Client host only: base URL the frontend uses to reach the API on the server.
VITE_API_BASE_URL=http://localhost:4000

VITE_DEMO_EMAIL=demo@voxmate.local
VITE_DEMO_PASSWORD=voxmate123

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Опционально: если задан, пароли SMTP пользователей (backend/src/auth.js,
# смотрят настройки "Отправка") шифруются в БД (AES-256-GCM), а не хранятся
# открытым текстом. Без ключа поведение как раньше (plaintext). Задать один
# раз и не менять — со сменой ключа старые зашифрованные пароли перестанут
# расшифровываться.
SMTP_ENCRYPTION_KEY=
